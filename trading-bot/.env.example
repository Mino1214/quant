# Copy to .env and fill in. Never commit .env or real keys.

# MySQL (optional if already in config loader default)
# DATABASE_URL=mysql+pymysql://user:pass@host/db?charset=utf8mb4

# Binance Futures API – Live 모드에서만 사용. 반드시 환경 변수로만 설정.
# BINANCE_API_KEY=your_api_key_here
# BINANCE_API_SECRET=your_api_secret_here

# 1m/5m/15m 봉 DB 저장 (서버 꺼졌다 켜도 갭 채우기·워밍업용). 0이면 저장 안 함.
# SAVE_CANDLES=1
